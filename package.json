{
  "name": "omezarr-tilesource",
  "version": "0.1.0",
  "description": "An OpenSeadragon tile source for the OME-Zarr bioimage file format",
  "homepage": "https://github.com/TissUUmaps/OMEZarrTileSource#readme",
  "bugs": "https://github.com/TissUUmaps/OMEZarrTileSource/issues",
  "license": "MIT",
  "author": "Jonas Windhager <jonas@windhager.io> (https://www.windhager.io)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TissUUmaps/OMEZarrTileSource.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/omezarr-tilesource.umd.cjs",
  "module": "./dist/omezarr-tilesource.js",
  "exports": {
    ".": {
      "import": "./dist/omezarr-tilesource.js",
      "require": "./dist/omezarr-tilesource.umd.cjs"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "fmt": "prettier --write --ignore-unknown .",
    "fmt:check": "prettier --check --ignore-unknown .",
    "test": "vitest run --passWithNoTests --coverage",
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "tsc && vite build --mode library",
    "preview": "vite preview"
  },
  "dependencies": {
    "@zarrita/storage": "^0.1.4",
    "ome-zarr.js": "^0.0.17",
    "zarrita": "^0.5.4"
  },
  "peerDependencies": {
    "openseadragon": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/openseadragon": "^5.0.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openseadragon": "^5.0.1",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "**/*.{js,ts}": "eslint --fix",
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
